{
  "datasets": [
    {
      "name": "resumen_clientes_bancario",
      "displayName": "Resumen Clientes Bancario",
      "config": {
        "version": "1.1",
        "source": "catalog_au.golden.resumenclientes",
        "dimensions": [
          {
            "name": "Cliente ID",
            "expr": "clienteid",
            "displayName": "Cliente ID"
          },
          {
            "name": "Nombre Cliente",
            "expr": "nombrecompleto",
            "displayName": "Nombre Cliente"
          },
          {
            "name": "Ciudad",
            "expr": "ciudad",
            "displayName": "Ciudad"
          },
          {
            "name": "Segmento Valor",
            "expr": "CASE\n  WHEN totalmonto >= 1000 THEN 'Alto valor'\n  WHEN totalmonto >= 500 THEN 'Valor medio'\n  ELSE 'Valor base'\nEND",
            "displayName": "Segmento de valor"
          },
          {
            "name": "Banda Actividad",
            "expr": "CASE\n  WHEN totaltransacciones >= 3 THEN 'Alta'\n  WHEN totaltransacciones = 2 THEN 'Media'\n  ELSE 'Baja'\nEND",
            "displayName": "Banda de actividad"
          },
          {
            "name": "Banda Ticket Promedio",
            "expr": "CASE\n  WHEN promediomonto >= 500 THEN 'Ticket alto'\n  WHEN promediomonto >= 250 THEN 'Ticket medio'\n  ELSE 'Ticket bajo'\nEND",
            "displayName": "Banda de ticket promedio"
          }
        ],
        "measures": [
          {
            "name": "total_clientes",
            "expr": "COUNT(DISTINCT clienteid)",
            "displayName": "Total clientes"
          },
          {
            "name": "monto_total",
            "expr": "SUM(totalmonto)",
            "displayName": "Monto total",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            }
          },
          {
            "name": "total_transacciones",
            "expr": "SUM(totaltransacciones)",
            "displayName": "Total transacciones",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            }
          },
          {
            "name": "monto_promedio_cliente",
            "expr": "MEASURE(monto_total) / MEASURE(total_clientes)",
            "displayName": "Monto promedio por cliente",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            }
          },
          {
            "name": "ticket_promedio",
            "expr": "AVG(promediomonto)",
            "displayName": "Ticket promedio",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            }
          }
        ]
      }
    }
  ],
